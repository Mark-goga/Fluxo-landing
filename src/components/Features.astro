---
import { pageAssetUrl } from "../config/site";
import type { LandingContent } from "../data/locales";

interface Props {
  content: LandingContent;
  routePath: string;
}

const { content, routePath } = Astro.props;
const { features } = content;

const sparkle = pageAssetUrl(routePath, "assets/sparkle.svg");
const cat = pageAssetUrl(routePath, "assets/cat.png");

const allCards = [...features.leftCards, ...features.rightCards];
---

<section class="features" id="features">
  <h2 class="section-title" set:html={features.titleHtml} />

  <div class="features-grid-wrap">
    <div class="features-floating">
      {allCards.map((card) => (
        <div class={`feat-sticker feat-sticker--${card.sticker}`}>
          <img src={pageAssetUrl(routePath, card.icon)} alt={card.iconAlt} />
        </div>
      ))}
      <div class="feat-cat-mini">
        <img src={cat} alt={features.catAlt} />
      </div>
      <div class="feat-ai-badge">
        <img src={sparkle} alt="" class="feat-ai-icon" /> {features.aiBadge}
      </div>
    </div>

    <div class="features-grid">
      {allCards.map((card) => (
        <div class="feat-card" style={`background:${card.bg}`}>
          <div class="feat-card-body">
            <p class="feat-card-title">{card.title}</p>
            <p class="feat-card-desc">{card.desc}</p>
          </div>
          <div class="feat-card-image" style={`background:${card.imageBg}`}>
            <img src={pageAssetUrl(routePath, card.image)} alt={card.imageAlt} />
          </div>
        </div>
      ))}
    </div>
  </div>

  <script>
    document.querySelectorAll<HTMLElement>('.feat-sticker, .feat-cat-mini, .feat-ai-badge').forEach(el => {
      let pointerDown = false;
      let isDragging = false;
      let startMouseX = 0, startMouseY = 0;
      const DRAG_THRESHOLD = 4;

      el.addEventListener('mousedown', (e: MouseEvent) => {
        pointerDown = true;
        isDragging = false;
        startMouseX = e.clientX;
        startMouseY = e.clientY;
        e.preventDefault();
      });

      window.addEventListener('mousemove', (e: MouseEvent) => {
        if (!pointerDown) return;
        const dx = e.clientX - startMouseX;
        const dy = e.clientY - startMouseY;
        if (!isDragging) {
          if (Math.abs(dx) < DRAG_THRESHOLD && Math.abs(dy) < DRAG_THRESHOLD) return;
          isDragging = true;
          el.style.transition = 'none';
          el.style.animationPlayState = 'paused';
          el.style.translate = '0 0';
          el.style.zIndex = '100';
          el.style.cursor = 'grabbing';
        }
        el.style.translate = `${dx}px ${dy}px`;
      });

      window.addEventListener('mouseup', () => {
        if (!pointerDown) return;
        pointerDown = false;
        if (!isDragging) return;
        isDragging = false;
        el.style.zIndex = '';
        el.style.cursor = '';
        el.style.transition = 'translate 0.65s cubic-bezier(0.34, 1.56, 0.64, 1)';
        el.style.translate = '0 0';
        el.addEventListener('transitionend', () => {
          el.style.transition = '';
          el.style.translate = '';
          el.style.animationPlayState = '';
        }, { once: true });
      });
    });
  </script>

  <div class="features-cta">
    <a href={features.cta.href} class="btn-primary" data-clarity-event={features.cta.clarityEvent}>
      {features.cta.label}
    </a>
  </div>
</section>
