---
import { pageAssetUrl } from "../config/site";
import type { LandingContent } from "../data/locales";

interface Props {
  content: LandingContent;
  routePath: string;
}

const { content, routePath } = Astro.props;
const logo = pageAssetUrl(routePath, "assets/LOGOFLUXOBlack.png");
const tiktok = pageAssetUrl(routePath, "assets/TiktokLogo.svg");
const xlogo = pageAssetUrl(routePath, "assets/XLogo.svg");
---

<footer class="footer">
  <div class="footer-top">
    <div class="footer-brand">
      <img src={logo} alt={content.footer.brandAlt} />
      <div class="footer-socials">
        {
          content.footer.socials.map((social) => (
            <a href={social.href} class="footer-social-btn" aria-label={social.label}>
              {social.label === "TikTok" && <img src={tiktok} alt="" />}
              {social.label === "X" && <img src={xlogo} alt="" />}
              {social.label === "Instagram" && (
                <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="2.5" y="2.5" width="15" height="15" rx="4" stroke="white" stroke-width="1.4" />
                  <circle cx="10" cy="10" r="3.5" stroke="white" stroke-width="1.4" />
                  <circle cx="14.25" cy="5.75" r="1" fill="white" />
                </svg>
              )}
            </a>
          ))
        }
      </div>
    </div>
    <div class="footer-cols">
      {
        content.footer.columns.map((column) => (
          <div class="footer-col">
            <div class="footer-col-title">{column.title}</div>
            <ul class="footer-links">
              {column.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
  <div class="footer-bottom">
    <span class="footer-copy">{content.footer.copyright}</span>
    <button type="button" class="footer-consent" onclick="window.displayPreferenceModal && window.displayPreferenceModal()">
      {content.footer.consentPreferences}
    </button>
  </div>
</footer>
