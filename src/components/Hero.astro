---
import { pageAssetUrl } from "../config/site";
import type { LandingContent } from "../data/locales";

interface Props {
  content: LandingContent;
  routePath: string;
}

const { content, routePath } = Astro.props;
const heroImage = pageAssetUrl(routePath, "assets/hero.png");
---

<section class="hero" id="start">
  <div class="hero-content">
    <div class="hero-text">
      <h1 set:html={content.hero.titleHtml} />
      <p class="hero-body">{content.hero.text}</p>
    </div>
    <div class="hero-buttons">
      <a href={content.hero.primaryCta.href} class="btn-primary" data-clarity-event={content.hero.primaryCta.clarityEvent}>
        {content.hero.primaryCta.label}
      </a>
      <a
        href={content.hero.secondaryCta.href}
        class="btn-secondary btn-secondary-lg"
        data-clarity-event={content.hero.secondaryCta.clarityEvent}
      >
        {content.hero.secondaryCta.label}
      </a>
    </div>
  </div>
  <div class="hero-image">
    <img src={heroImage} alt={content.hero.imageAlt} />
  </div>
</section>
