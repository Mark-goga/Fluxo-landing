---
import type { LandingContent } from "../data/locales";

interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
---

<section class="pricing" id="pricing">
  <div class="pricing-header">
    <h2 class="section-title" set:html={content.pricing.titleHtml} />
  </div>
  <div class="pricing-grid">
    {
      content.pricing.cards.map((card) => (
        <div class={`pricing-card${card.featured ? " pricing-card--featured" : ""}`}>
          {card.badge && <div class="pricing-badge">{card.badge}</div>}
          <div>
            <div class="pricing-name">{card.name}</div>
            <div class="pricing-price">
              <span class="pricing-amount">{card.amount}</span>
              <span class="pricing-period">{card.period}</span>
            </div>
          </div>
          <div class="pricing-divider" />
          <ul class="pricing-features">
            {card.features.map((feature) => (
              <li class={feature.included ? "" : "disabled"}>
                <span class={`check ${feature.included ? "check--yes" : "check--no"}`}>
                  {feature.included ? "✓" : "✗"}
                </span>
                {feature.text}
              </li>
            ))}
          </ul>
          <a
            href={card.cta.href}
            class={`pricing-btn pricing-btn--${card.cta.variant}`}
            data-clarity-event={card.cta.clarityEvent}
          >
            {card.cta.label}
          </a>
        </div>
      ))
    }
  </div>
</section>
