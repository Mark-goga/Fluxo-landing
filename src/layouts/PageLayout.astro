---
import { absoluteUrl, pageAssetUrl, siteConfig } from "../config/site";
import TrackingScripts from "../components/TrackingScripts.astro";
import "../styles/styles.css";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  routePath: string;
  lang?: string;
  baseHref?: string;
  robots?: string;
}

const { title, description, canonicalPath, routePath, lang = "en", baseHref, robots = "index, follow" } = Astro.props;
const canonicalUrl = absoluteUrl(canonicalPath);
const scriptPath = pageAssetUrl(routePath, siteConfig.scriptPath);
const favicon = pageAssetUrl(routePath, "assets/favicon.png");
const faviconDark = pageAssetUrl(routePath, "assets/favicon-dark.png");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {baseHref && <base href={baseHref} />}
    <title>{title}</title>
    <TrackingScripts />

    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#4C27E3" />
    <link rel="icon" type="image/png" href={favicon} />
    <link rel="icon" type="image/png" href={faviconDark} media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href={favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wght@8..144,100..900&display=swap"
      rel="stylesheet"
    />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body>
    <slot />
    <script src={scriptPath} defer></script>
  </body>
</html>
