---
import PageLayout from "./PageLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Modal from "../components/Modal.astro";
import { siteConfig, pageAssetUrl, absoluteUrl, type LocaleKey } from "../config/site";
import { landingContent, blogContent, blogLanguageNav, type BlogSlug } from "../data/locales";

interface Props {
  slug: string;
  locale?: LocaleKey;
}

const { slug, locale = "en" } = Astro.props;

const content = landingContent[locale];
const articles = blogContent[locale] ?? blogContent.en;
const article = articles[slug as keyof typeof articles];

if (!article) {
  throw new Error(`Unknown blog article "${slug}" for locale "${locale}"`);
}

const routePath = article.routePath;
const heroImage = pageAssetUrl(routePath, article.heroAsset);
const languageNav = blogLanguageNav(slug as BlogSlug);
const alternates = languageNav.map((option) => ({
  hreflang: option.locale,
  href: absoluteUrl(option.href),
}));
alternates.push({ hreflang: "x-default", href: absoluteUrl(blogContent.en[slug as BlogSlug].routePath) });
---

<PageLayout
  title={article.meta.title}
  description={article.meta.description}
  canonicalPath={routePath}
  routePath={routePath}
  lang={locale}
  alternates={alternates}
>
  <Header content={content} routePath={routePath} languageNav={languageNav} />

  <main class="article-page">
    <article class="article">

      <div class="article-header">
        <p class="article-category">{article.category}</p>
        <h1 class="article-title">{article.title}</h1>
        <p class="article-subtitle">{article.subtitle}</p>
        <div class="article-meta">
          <span>{article.author}</span>
          <span class="article-meta-dot">·</span>
          <span>{article.readTime}</span>
        </div>
      </div>

      <div class="article-hero">
        <img src={heroImage} alt={article.heroAlt} />
      </div>

      <div class="article-body" set:html={article.bodyHtml} />
    </article>
  </main>

  <Footer content={content} routePath={routePath} />
  <Modal content={content} />
</PageLayout>

<script define:vars={{ leadsUrl: `${siteConfig.leadsApiUrl}/leads`, applicationId: siteConfig.applicationId, toast: content.toast }}>
  (() => {
    const modal = document.querySelector("[data-lead-modal]");
    const toastEl = document.querySelector("[data-lead-toast]");
    let toastTimer, lastFocused = null;

    const showToast = (message, isError) => {
      if (!toastEl) return;
      toastEl.textContent = message;
      toastEl.classList.toggle("lead-toast--error", Boolean(isError));
      toastEl.hidden = false;
      void toastEl.offsetWidth;
      toastEl.classList.add("lead-toast--visible");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toastEl.classList.remove("lead-toast--visible");
        setTimeout(() => { toastEl.hidden = true; }, 300);
      }, 4000);
    };

    const openModal = (from) => {
      if (!modal) return;
      const form = modal.querySelector("[data-lead-form]");
      if (form && from) form.setAttribute("data-from", from);
      lastFocused = document.activeElement;
      modal.hidden = false;
      void modal.offsetWidth;
      modal.classList.add("lead-modal--open");
      document.body.style.overflow = "hidden";
      const input = modal.querySelector("input");
      if (input) setTimeout(() => input.focus(), 50);
    };

    const closeModal = () => {
      if (!modal) return;
      modal.classList.remove("lead-modal--open");
      document.body.style.overflow = "";
      setTimeout(() => { modal.hidden = true; }, 250);
      if (lastFocused && typeof lastFocused.focus === "function") lastFocused.focus();
    };

    document.querySelectorAll("[data-modal-open]").forEach((trigger) => {
      trigger.addEventListener("click", () => openModal(trigger.getAttribute("data-from")));
    });

    if (modal) {
      modal.querySelectorAll("[data-modal-close]").forEach((el) => {
        el.addEventListener("click", closeModal);
      });
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal && !modal.hidden) closeModal();
    });

    const buildUtmMetadata = () => {
      const params = new URLSearchParams(window.location.search);
      return Object.fromEntries(Array.from(params.entries()).filter(([key]) => key.startsWith("utm_")));
    };

    const buildLeadMetadata = (from) => ({
      from,
      page: window.location.href,
      path: window.location.pathname,
      locale: document.documentElement.lang || "unknown",
      referrer: document.referrer,
      userAgent: navigator.userAgent,
      timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
      utm: buildUtmMetadata(),
    });

    document.querySelectorAll("[data-lead-form]").forEach((form) => {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const input = form.querySelector('input[type="email"]');
        const button = form.querySelector('button[type="submit"]');
        const email = input ? input.value.trim() : "";
        const from = form.getAttribute("data-from") || "unknown";
        if (!input || !input.checkValidity() || !email) { if (input) input.reportValidity(); return; }
        if (button) button.disabled = true;
        form.setAttribute("aria-busy", "true");
        try {
          const res = await fetch(leadsUrl, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, applicationId, metadata: buildLeadMetadata(from) }),
          });
          if (!res.ok) throw new Error();
          if (input) input.value = "";
          if (modal && form.closest("[data-lead-modal]")) closeModal();
          showToast(toast.success, false);
        } catch {
          showToast(toast.error, true);
        } finally {
          if (button) button.disabled = false;
          form.removeAttribute("aria-busy");
        }
      });
    });
  })();
</script>

<style>
  .article-page {
    padding-top: 80px;
    background: #F3F3F3;
    min-height: 100vh;
  }

  .article {
    max-width: 1192px;
    margin: 0 auto;
    padding: 60px 24px 100px;
  }

  /* Header */
  .article-header {
    max-width: 680px;
    margin: 0 auto 40px;
  }

  .article-category {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6B6B6B;
    margin: 0 0 20px;
  }

  .article-title {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 42px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0E0E0E;
    margin: 0 0 16px;
  }

  .article-subtitle {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 1.5;
    color: #3D3D3D;
    margin: 0 0 24px;
  }

  .article-meta {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 14px;
    color: #6B6B6B;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .article-meta-dot {
    color: #B0B0B0;
  }

  /* Hero image */
  .article-hero {
    max-width: 920px;
    margin: 0 auto 56px;
    border-radius: 16px;
    overflow: hidden;
  }

  .article-hero img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    max-height: 520px;
  }

  /* Body */
  .article-body {
    max-width: 680px;
    margin: 0 auto;
  }

  /* Article body is injected via set:html, so its descendants are not
     touched by Astro's scoping — target them with :global(). */
  .article-body :global(p) {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.7;
    color: #1C1C1C;
    margin: 0 0 28px;
  }

  .article-body :global(h2) {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: #0E0E0E;
    margin: 52px 0 16px;
  }

  .article-body :global(h3) {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 22px;
    font-weight: 600;
    line-height: 1.3;
    color: #0E0E0E;
    margin: 36px 0 12px;
  }

  .article-body :global(strong) {
    font-weight: 600;
    color: #0E0E0E;
  }

  .article-body :global(em) {
    font-style: italic;
  }

  .article-body :global(a) {
    color: #4C27E3;
    text-decoration: underline;
    text-decoration-color: rgba(76, 39, 227, 0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s;
  }

  .article-body :global(a:hover) {
    text-decoration-color: #4C27E3;
  }

  .article-body :global(button.btn-secondary) {
    border: none;
    cursor: pointer;
  }

  .article-body :global(.article-rule) {
    border: none;
    border-top: 1px solid #E8E8E8;
    margin: 40px 0;
  }

  .article-body :global(.sources-title) {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #6B6B6B;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 16px;
  }

  .article-body :global(.sources-list) {
    padding-left: 20px;
    margin: 0;
  }

  .article-body :global(.sources-list li) {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #6B6B6B;
    margin-bottom: 10px;
  }

  .article-body :global(.sources-list a) {
    color: #6B6B6B;
    font-size: 13px;
    word-break: break-all;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.7;
    color: #1C1C1C;
    margin: 0 0 28px;
    padding-left: 28px;
  }

  .article-body :global(ul li),
  .article-body :global(ol li) {
    margin-bottom: 12px;
    padding-left: 6px;
  }

  .article-body :global(ul li:last-child),
  .article-body :global(ol li:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .article {
      padding: 40px 20px 80px;
    }

    .article-title {
      font-size: 30px;
    }

    .article-subtitle {
      font-size: 18px;
    }

    .article-hero {
      margin-bottom: 40px;
    }

    .article-body :global(p) {
      font-size: 18px;
    }

    .article-body :global(h2) {
      font-size: 24px;
      margin-top: 40px;
    }

    .article-body :global(h3) {
      font-size: 20px;
    }
  }
</style>
