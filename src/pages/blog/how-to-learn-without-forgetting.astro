  }

  .article-rule {
    border: none;
    border-top: 1px solid #E8E8E8;
    margin: 40px 0;
  }

  .sources-title {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #6B6B6B;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 16px;
  }

  .sources-list {
    padding-left: 20px;
