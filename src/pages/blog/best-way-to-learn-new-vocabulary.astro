  }

  @media (max-width: 768px) {
    .article {
      padding: 40px 20px 80px;
    }

    .article-title {
      font-size: 30px;
    }

    .article-subtitle {
      font-size: 18px;
    }

    .article-hero {
      margin-bottom: 40px;
