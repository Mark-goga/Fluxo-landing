    max-width: 680px;
    margin: 0 auto 40px;
  }

  .article-category {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6B6B6B;
    margin: 0 0 20px;
  }

  .article-title {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 42px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0E0E0E;
    margin: 0 0 16px;
  }

  .article-subtitle {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 1.5;
    color: #3D3D3D;
    margin: 0 0 24px;
  }

  .article-meta {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 14px;
    color: #6B6B6B;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .article-meta-dot {
    color: #B0B0B0;
  }

  /* Hero image */
  .article-hero {
    max-width: 920px;
    margin: 0 auto 56px;
    border-radius: 16px;
    overflow: hidden;
  }

  .article-hero img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    max-height: 520px;
  }

  /* Body */
  .article-body {
    max-width: 680px;
    margin: 0 auto;
  }

  .article-body p {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.7;
    color: #1C1C1C;
    margin: 0 0 28px;
  }

  .article-body h2 {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: #0E0E0E;
    margin: 52px 0 16px;
  }

  .article-body h3 {
    font-family: 'Roboto Flex', sans-serif;
    font-size: 22px;
    font-weight: 600;
    line-height: 1.3;
    color: #0E0E0E;
    margin: 36px 0 12px;
  }

  .article-body strong {
    font-weight: 600;
    color: #0E0E0E;
  }

  .article-body em {
    font-style: italic;
  }

  .article-body a {
    color: #4C27E3;
    text-decoration: underline;
    text-decoration-color: rgba(76, 39, 227, 0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s;
  }

  .article-body a:hover {
    text-decoration-color: #4C27E3;
  }

  .article-body button.btn-secondary {
    border: none;
