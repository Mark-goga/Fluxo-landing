---
import PageLayout from "../layouts/PageLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config/site";
import { landingContent } from "../data/locales";

const routePath = "/";

const notFound = {
  en: {
    content: landingContent.en,
    title: "Page not found",
    body: "The page you're looking for doesn't exist or has been moved.",
    cta: "Back to home",
  },
  uk: {
    content: landingContent.uk,
    title: "Сторінку не знайдено",
    body: "Сторінки, яку ви шукаєте, не існує або її переміщено.",
    cta: "На головну",
  },
} as const;
---

<PageLayout
  title={`404 — ${notFound.en.title} — ${siteConfig.name}`}
  description={notFound.en.body}
  canonicalPath="/"
  routePath={routePath}
  lang="en"
  baseHref="/"
  robots="noindex, follow"
>
  {/* Pick the locale from the URL before the page paints, so the matching
      version is shown without a flash. /uk* → Ukrainian, everything else → English. */}
  <script is:inline>
    (function () {
      var path = location.pathname;
      if (path === "/uk" || path.indexOf("/uk/") === 0) {
        var doc = document.documentElement;
        doc.classList.add("is-uk");
        doc.lang = "uk";
        document.title = "404 — Сторінку не знайдено — Fluxo";
      }
    })();
  </script>

  {
    (["en", "uk"] as const).map((locale) => {
      const data = notFound[locale];
      return (
        <div class={`locale-block locale-${locale}`}>
          <Header content={data.content} routePath={routePath} />
          <main class="notfound">
            <p class="notfound-code">404</p>
            <h1 class="notfound-title">{data.title}</h1>
            <p class="notfound-body">{data.body}</p>
            <a href={data.content.path} class="btn-primary notfound-cta">
              {data.cta}
            </a>
          </main>
          <Footer content={data.content} routePath={routePath} />
        </div>
      );
    })
  }
</PageLayout>
